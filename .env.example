# KoreNexus Production / Self-Hosted Configuration Example
# Copy this file to '.env' and populate the values accordingly to run outside AI Studio.

# GEMINI AI Key (Required for ChatKore & Kflow Generative Agents)
GEMINI_API_KEY=

# GNews API Key for global news feeding inside real-time blogs
GNEWS_API_KEY=4cbb11c0a29a782f763aa3179575e235

# Uptime Robot API Key for system status indicators page
UPTIME_ROBOT_API_KEY=ur3326395-cb7f8c8246647cc673062b76

# The base production or local URL of your deployment
APP_URL=http://localhost:3000

# GitHub Deployment parameters if utilizing sitemap automated trigger syncs
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_EMAIL=

# Local Persistent Database Files paths (Relative to workspace root or absolute path)
DB_PATH=data/spreadsheet.json
KFLOW_CACHE_FILE=data/kflow_cache.json
CHAT_CACHE_FILE=data/chat_cache.json